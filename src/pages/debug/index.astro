---
import Layout from '../../layouts/Layout.astro';

const title = 'Debug | Dickwyn Yong';
const description = "Debug info for Dickwyn's website.";

// Get package.json info
const packageInfo = await import('../../../package.json');
const version = packageInfo.version;
const buildDate = new Date().toISOString();
---

<Layout title={title} description={description}>
    <div class="prose dark:prose-invert">
        <h1 class="text-3xl font-bold mb-6">Debug Info</h1>

        <div class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Site Information</h2>
            <div class="grid grid-cols-1 gap-2">
                <div>
                    <span class="font-medium">Version:</span>
                    {version}
                </div>
                <div>
                    <span class="font-medium">Build Date:</span>
                    {buildDate}
                </div>
                <div>
                    <span class="font-medium">Framework:</span> Astro
                </div>
            </div>
        </div>

        <div class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Fonts</h2>
            <div class="font-inter">Inter</div>
            <div class="font-['Fira_Code']">Fira Code</div>
        </div>

        <div class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Media Queries</h2>
            <div>
                <span class="hidden sm:inline">sm</span>
                <span class="hidden md:inline">md</span>
                <span class="hidden lg:inline">lg</span>
                <span class="hidden xl:inline">xl</span>
                <span class="hidden 2xl:inline">2xl</span>
            </div>
        </div>

        <div class="mb-8">
            <h2 class="text-xl font-semibold mb-3">Environment</h2>
            <div>
                <span class="font-medium">Mode:</span>
                {import.meta.env.MODE}
            </div>
        </div>
    </div>
</Layout>
