---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { formatDate } from '../../utils';

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Base title="Blog" description="Read my blog.">
	<section class="grid gap-3">
		{
			posts.map((post) => (
				<a
					href={`/blog/${post.data.slug}`}
					class="block py-4 px-4 -mx-4 border-2 border-transparent rounded-lg !no-underline transition-all duration-200 ease-in-out hover:bg-[var(--color-brand-hover)] hover:transform hover:-translate-y-0.5"
				>
					<div>
						<p class="text-sm text-neutral-600 dark:text-neutral-400">
							{formatDate(post.data.date, false)}
						</p>
						<h2 class="my-2 text-xl text-neutral-900 dark:text-neutral-100 tracking-tight">
							{post.data.title}
						</h2>
						{post.data.subtitle && (
							<h3 class="text-base italic text-neutral-900 dark:text-neutral-100 tracking-tight">
								{post.data.subtitle}
							</h3>
						)}
						<p class="text-neutral-900 dark:text-neutral-100 tracking-tight">
							{post.data.description}
						</p>
					</div>
				</a>
			))
		}
	</section>
</Base>
