---
import Layout from '../../layouts/Layout.astro';

const title = 'Blog | Dickwyn Yong';
const description = 'Articles and thoughts by Dickwyn Yong.';
---

<Layout title={title} description={description}>
    <div class="flex flex-col items-center justify-center py-20">
        <h1 class="text-3xl font-bold mb-4">Blog Coming Soon</h1>
        <p class="text-lg text-neutral-600 dark:text-neutral-400 mb-8 text-center max-w-md">
            I'm currently migrating my blog content to Astro. Check back soon for articles and
            thoughts.
        </p>
        <div class="w-24 h-1 bg-gray-300 dark:bg-gray-700 mb-8"></div>
        <p class="text-sm text-neutral-500">
            In the meantime, feel free to check out my <a
                href="/things"
                class="underline hover:text-neutral-800 dark:hover:text-neutral-200">things page</a
            >.
        </p>
    </div>
</Layout>
