---
interface Props {
	id?: string;
	title?: string;
	start?: number;
	className?: string;
}

const { id, title = 'YouTube video', start, className = '' } = Astro.props;
---

{
	id ? (
		<div class={className} style="position: relative; padding-bottom: 56.25%; height: 0;">
			<iframe
				src={`https://www.youtube.com/embed/${id}${start ? `?start=${start}` : ''}`}
				title={title}
				loading="lazy"
				allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
				allowfullscreen
				style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0;"
			/>
		</div>
	) : (
		<p>No id provided</p>
	)
}
