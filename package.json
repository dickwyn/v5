{
  "name": "v5",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npx generate-favicons --source images/brand/icon-dark.svg --destination ./public",
    "dev": "yarn predev && next dev",
    "prebuild": "npx generate-favicons --source images/brand/icon-dark.svg --destination ./public",
    "build": "yarn prebuild && next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "prettier": "prettier --write \"**/*.{ts,tsx,json,mdx}\""
  },
  "dependencies": {
    "@emotion/react": "^11.9.3",
    "@emotion/styled": "^11.9.3",
    "@fisch0920/use-dark-mode": "^2.4.0",
    "@mui/icons-material": "^5.8.4",
    "@mui/material": "^5.9.1",
    "dayjs": "^1.11.4",
    "gray-matter": "^4.0.3",
    "nanoid": "^4.0.0",
    "next": "^12.2.0",
    "next-mdx-remote": "^4.1.0",
    "nextjs-google-analytics": "^1.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-lite-youtube-embed": "^2.3.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^12.2.3",
    "@types/node": "17.0.23",
    "@typescript-eslint/eslint-plugin": "^5.17.0",
    "@typescript-eslint/parser": "^5.17.0",
    "eslint": "^8.2.0",
    "eslint-config-airbnb": "19.0.4",
    "eslint-config-airbnb-typescript": "^16.1.4",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.25.3",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.7",
    "modern-favicons": "^1.0.3",
    "prettier": "^2.6.1",
    "sass": "^1.54.0",
    "typescript": "^4.7.4"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix"
    ],
    "*.{html,js}": [
      "prettier --write"
    ]
  }
}
